# ===================================================================
# NUTA E-COMMERCE PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# ===================================================================
# © 2025 Steve Have It. All rights reserved.
# Copy this file to .env and fill in your actual credentials
# ===================================================================

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
PORT=3001
NODE_ENV=production
APP_NAME=NUTA
APP_URL=your_backend_url
FRONTEND_URL=your_frontend_url

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# Supabase PostgreSQL Database
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@host:5432/database

# Database Connection (Direct PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name

# ===================================================================
# AUTHENTICATION & SECURITY
# ===================================================================
JWT_SECRET=your_jwt_secret_key_here
SESSION_DRIVER=file
CACHE_DRIVER=file
APP_KEY=base64:your_app_key_here

# Manus OAuth Configuration
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=Your Name

# ===================================================================
# CORS CONFIGURATION
# ===================================================================
CORS_ORIGIN=your_frontend_url

# ===================================================================
# STORAGE & MEDIA
# ===================================================================
# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===================================================================
# EMAIL CONFIGURATION
# ===================================================================
# Gmail SMTP Settings
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME=Your App Name

# SMTP Configuration (Alternative naming)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ===================================================================
# PAYMENT GATEWAYS
# ===================================================================
# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_CALLBACK_URL=your_backend_url/api/payment/paypal/callback

# M-PESA Configuration
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=sandbox

# ===================================================================
# SMS & WHATSAPP NOTIFICATIONS
# ===================================================================
# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# WhatsApp API
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE=your_whatsapp_business_phone

# ===================================================================
# AI & RECOMMENDATION SYSTEM
# ===================================================================
AI_ENGINE=DeepSeek
AI_MODEL=your_ai_model
AI_ENDPOINT=your_ai_endpoint
AI_API_KEY=your_ai_api_key
AI_API_URL=your_ai_api_url
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# ===================================================================
# LOYALTY POINTS SYSTEM
# ===================================================================
LOYALTY_ENABLED=true
LOYALTY_POINTS_PER_500KES=9
LOYALTY_POINTS_PER_KES=0.018
LOYALTY_POINT_VALUE=3
LOYALTY_POINT_VALUE_KES=3
LOYALTY_WITHDRAWAL_PERIOD_DAYS=3
LOYALTY_WITHDRAWAL_DAYS=3
LOYALTY_NOTIFICATION_EMAIL=your_email@example.com

# ===================================================================
# SPIN WHEEL & REWARDS
# ===================================================================
SPIN_ENABLED=true
SPIN_REWARD_TIERS=5:100,10:200,20:500,30:1000
REWARD_TIERS=100,200,500,1000
SPIN_ELIGIBILITY=5,10,20,30
SPIN_FESTIVE_MODE=true
SPIN_FESTIVE_BONUS_PERCENT=15

# ===================================================================
# GIVEAWAYS & PROMOTIONS
# ===================================================================
GIVEAWAY_AUTO_MODE=true
GIVEAWAY_EMAIL_ALERTS=true
GIVEAWAY_THRESHOLD=2000
BLACKFRIDAY_MULTIPLIER=2

# ===================================================================
# AFFILIATE & REFERRAL SYSTEM
# ===================================================================
AFFILIATE_ENABLED=true
AFFILIATE_BASE_PERCENT=5
AFFILIATE_COMMISSION_PERCENT=5
AFFILIATE_RANK_BONUS=2
AFFILIATE_TIERS=Bronze,Silver,Gold,Diamond
AFFILIATE_BONUS_THRESHOLD=20
AFFILIATE_PAYOUT_DAY=1
AFFILIATE_EMAIL_NOTIFICATIONS=true
AFFILIATE_ADMIN_APPROVAL_REQUIRED=true

# ===================================================================
# MARKETING AUTOMATION
# ===================================================================
AI_MARKETING_ENABLED=true
AI_SUGGESTION_INTERVAL_HOURS=24
AI_TRACK_AFFILIATE_PERFORMANCE=true
AI_AUTO_RANK_UP=true
AI_DETECT_FRAUD=true
AI_SEND_REPORTS=true

# Marketing Campaigns
EMAIL_CAMPAIGNS_ENABLED=true
SMS_CAMPAIGNS_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true

# Marketing UI
POPUP_ENABLED=true
POPUP_DISPLAY_FREQUENCY=7
BANNER_ROTATION_INTERVAL=10
AFFILIATE_PROMO_MESSAGE=Earn 5% on every referral you bring!
LOYALTY_PROMO_MESSAGE=Spend 500 KES and get 9 loyalty points!

# ===================================================================
# DELIVERY & LOGISTICS
# ===================================================================
DELIVERY_FEE_NAIROBI=100
DELIVERY_FEE_NEIGHBOR_COUNTIES=300
DELIVERY_FEE_REST=variable
DELIVERY_MAX_NAIROBI_DAYS=3
DELIVERY_MAX_NEIGHBOR_DAYS=5
DELIVERY_MAX_OTHER_DAYS=7
DELIVERY_EXTRA_KES_PER_KG=50

# ===================================================================
# CURRENCY & EXCHANGE
# ===================================================================
DEFAULT_CURRENCY=KES
DEFAULT_CURRENCY_SYMBOL=KSh
CURRENCY_FORMAT=0,0.00
TIMEZONE=Africa/Nairobi
LANGUAGE=en
EXCHANGE_API_ENABLED=false
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_UPDATE_INTERVAL_HOURS=12

# ===================================================================
# ADMIN & MANAGEMENT
# ===================================================================
ADMIN_EMAIL=admin@example.com
ADMIN_AI_ASSISTANT=true
ADMIN_AUTO_BACKUP=true
ADMIN_BACKUP_INTERVAL_DAYS=7
ADMIN_REPORT_EMAIL=admin@example.com
CRM_ENABLED=true
CMS_ENABLED=true
INVENTORY_AUTO_ALERTS=true
ORDER_STATUS_UPDATES=true
AI_ERROR_DETECTION=true

# ===================================================================
# SECURITY & COMPLIANCE
# ===================================================================
DATA_ENCRYPTION_ENABLED=true
GDPR_COMPLIANT=true
ANTI_FRAUD_MONITORING=true
CUSTOMER_DATA_PROTECTION=true
RETURN_POLICY_LINK=your_frontend_url/return-policy
TERMS_AND_CONDITIONS_LINK=your_frontend_url/terms
PRIVACY_POLICY_LINK=your_frontend_url/privacy

# ===================================================================
# FEATURE FLAGS
# ===================================================================
ENABLE_GUEST_CHECKOUT=true
ENABLE_LOYALTY_SYSTEM=true
ENABLE_REFERRAL_SYSTEM=true
ENABLE_SPIN_WHEEL=true
ENABLE_AFFILIATE_TRACKING=true
ENABLE_AI_ASSISTANT=true
ENABLE_MARKETING_AUTOMATION=true

# ===================================================================
# SYSTEM SETTINGS
# ===================================================================
QUEUE_CONNECTION=database
LOG_CHANNEL=stack
APP_DEBUG=false

# ===================================================================
# PAYMENT SETTINGS
# ===================================================================
PAYMENT_MPESA_ENABLED=false
PAYMENT_PAYPAL_ENABLED=true

# ===================================================================
# VITE FRONTEND VARIABLES (Exposed to client)
# ===================================================================
VITE_API_URL=your_backend_url
VITE_FRONTEND_URL=your_frontend_url
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# ===================================================================
# END OF CONFIGURATION
# ===================================================================
